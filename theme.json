{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"custom": true,
			"customDuotone": false,
			"customGradient": true,
			"palette": [
				{
					"color": "#0A2650",
					"name": "Azul Profundo",
					"slug": "primary"
				},
				{
					"color": "#173A7A",
					"name": "Azul Oscuro",
					"slug": "secondary"
				},
				{
					"color": "#176EB5",
					"name": "Azul Medio",
					"slug": "accent"
				},
				{
					"color": "#F28D0A",
					"name": "Naranja",
					"slug": "highlight"
				},
				{
					"color": "#F4F6F8",
					"name": "Gris Claro",
					"slug": "surface"
				},
				{
					"color": "#FFFFFF",
					"name": "Blanco",
					"slug": "base"
				},
				{
					"color": "#1A1A2E",
					"name": "Negro Suave",
					"slug": "contrast"
				},
				{
					"color": "#4A5568",
					"name": "Gris Texto",
					"slug": "muted"
				}
			],
			"gradients": [
				{
					"gradient": "linear-gradient(135deg, #0A2650 0%, #176EB5 100%)",
					"name": "Azul Diagonal",
					"slug": "blue-diagonal"
				},
				{
					"gradient": "linear-gradient(135deg, #0A2650 0%, #173A7A 50%, #176EB5 100%)",
					"name": "Azul Completo",
					"slug": "blue-full"
				},
				{
					"gradient": "linear-gradient(135deg, #173A7A 0%, #F28D0A 100%)",
					"name": "Marca",
					"slug": "brand"
				}
			]
		},
		"typography": {
			"customFontSize": true,
			"dropCap": false,
			"fluid": true,
			"fontSizes": [
				{ "fluid": { "min": "0.75rem", "max": "0.875rem" }, "name": "XS", "size": "0.875rem", "slug": "xs" },
				{ "fluid": { "min": "0.875rem", "max": "1rem" }, "name": "Pequeño", "size": "1rem", "slug": "sm" },
				{ "fluid": { "min": "1rem", "max": "1.125rem" }, "name": "Mediano", "size": "1.125rem", "slug": "md" },
				{ "fluid": { "min": "1.125rem", "max": "1.375rem" }, "name": "Grande", "size": "1.375rem", "slug": "lg" },
				{ "fluid": { "min": "1.375rem", "max": "1.875rem" }, "name": "XL", "size": "1.875rem", "slug": "xl" },
				{ "fluid": { "min": "1.875rem", "max": "2.5rem" }, "name": "2XL", "size": "2.5rem", "slug": "2xl" },
				{ "fluid": { "min": "2rem", "max": "3.5rem" }, "name": "3XL", "size": "3.5rem", "slug": "3xl" },
				{ "fluid": { "min": "2.5rem", "max": "4.5rem" }, "name": "Hero", "size": "4.5rem", "slug": "hero" }
			],
			"fontFamilies": [
				{
					"fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
					"name": "Sistema (por defecto)",
					"slug": "system"
				},
				{
					"fontFamily": "'Inter', system-ui, sans-serif",
					"name": "Inter",
					"slug": "inter",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "300 700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/inter-variable.woff2"]
						}
					]
				},
				{
					"fontFamily": "Georgia, 'Times New Roman', serif",
					"name": "Georgia (Serif)",
					"slug": "serif"
				},
				{
					"fontFamily": "'Courier New', Courier, monospace",
					"name": "Monoespaciada",
					"slug": "mono"
				}
			]
		},
		"spacing": {
			"customSpacingSize": true,
			"units": ["px", "%", "em", "rem", "vw", "vh"],
			"spacingSizes": [
				{ "name": "1", "size": "0.25rem", "slug": "10" },
				{ "name": "2", "size": "0.5rem", "slug": "20" },
				{ "name": "3", "size": "0.75rem", "slug": "30" },
				{ "name": "4", "size": "1rem", "slug": "40" },
				{ "name": "5", "size": "1.5rem", "slug": "50" },
				{ "name": "6", "size": "2rem", "slug": "60" },
				{ "name": "7", "size": "3rem", "slug": "70" },
				{ "name": "8", "size": "4rem", "slug": "80" },
				{ "name": "9", "size": "6rem", "slug": "90" },
				{ "name": "10", "size": "8rem", "slug": "100" }
			]
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1280px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{ "name": "Suave", "shadow": "0 2px 8px rgba(10,38,80,0.08)", "slug": "soft" },
				{ "name": "Media", "shadow": "0 4px 20px rgba(10,38,80,0.12)", "slug": "medium" },
				{ "name": "Fuerte", "shadow": "0 8px 40px rgba(10,38,80,0.20)", "slug": "strong" }
			]
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"customFontSize": true
				}
			},
			"core/button": {
				"border": {
					"radius": true
				}
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)",
			"fontSize": "var(--wp--preset--font-size--md)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--60)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--3xl)",
					"fontWeight": "700",
					"lineHeight": "1.15"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--highlight)"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				"typography": {
					"textDecoration": "none"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--highlight)",
					"text": "var(--wp--preset--color--base)"
				},
				"typography": {
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"spacing": {
					"padding": {
						"top": "0.875rem",
						"bottom": "0.875rem",
						"left": "1.75rem",
						"right": "1.75rem"
					}
				},
				"border": {
					"radius": "6px"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary)"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				}
			},
			"core/site-logo": {
				"spacing": {
					"margin": { "top": "0", "bottom": "0" }
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--surface)"
				},
				"border": {
					"color": "var(--wp--preset--color--surface)"
				}
			},
			"core/image": {
				"border": {
					"radius": "8px"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--highlight)",
					"style": "solid",
					"width": "0 0 0 4px"
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--60)"
					}
				}
			}
		}
	},
	"templateParts": [
		{ "area": "header", "name": "header", "title": "Cabecera" },
		{ "area": "header", "name": "header-minimal", "title": "Cabecera Mínima (Checkout)" },
		{ "area": "footer", "name": "footer", "title": "Pie de página" }
	],
	"customTemplates": [
		{ "name": "page-services", "postTypes": ["page"], "title": "Página de Servicios" },
		{ "name": "page-contact", "postTypes": ["page"], "title": "Página de Contacto" },
		{ "name": "page-fullwidth", "postTypes": ["page"], "title": "Página Ancho Completo" }
	],
	"patterns": [
		"hero-section",
		"video-autoplay-section",
		"services-section",
		"portfolio-grid",
		"testimonials-section",
		"contact-section",
		"cta-banner",
		"stats-counter",
		"woocommerce-products-featured"
	]
}
