# Normaliza saltos de línea a LF en el servidor (Linux)
* text=auto eol=lf
*.php text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.pot text eol=lf

# Archivos binarios — no tocar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.ico binary
